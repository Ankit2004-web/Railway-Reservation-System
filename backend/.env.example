DB_SERVER=(localdb)\MSSQLLocalDB
DB_NAME=RailwayReservation
DB_USER=
DB_PASSWORD=
DB_TRUSTED_CONNECTION=true

JWT_SECRET=your_jwt_secret_here
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000

ADMIN_EMAIL=admin@railway.com
ADMIN_PASSWORD=Admin@123

# Logging
LOG_LEVEL=info

# Rate limits (requests per window)
RATE_LIMIT_API=300
RATE_LIMIT_AUTH=20
RATE_LIMIT_BOOKING=30

# Razorpay (optional - dev mode works without keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email for password reset (optional - dev mode shows reset link in API response)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
